{
  "name": "ralseibot",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun --bun tsc --noEmit",
    "test": "bun --bun test",
    "extract-sprites": ".venv/bin/python ./static/sprites/extract-sprites.py",
    "start": "bun --bun src/index.ts",
    "deploy-commands": "bun --bun src/deploy-commands.js",
    "watch": "bun --bun tsc --watch",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix"
  },
  "keywords": [],
  "author": "@BananaJeanss",
  "license": "MIT",
  "description": "A Discord Bot for all your Ralsei-related needs, built with TypeScript and Discord.js",
  "dependencies": {
    "@atproto/api": "^0.19.4",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@napi-rs/canvas": "^0.1.97",
    "@snazzah/davey": "^0.1.10",
    "bad-words": "^4.0.0",
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
